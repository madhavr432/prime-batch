   "source": [
    "#vectorisation\n",
    "arr = np.array([1,2,3,4,5])\n",
    "arr2 = np.array([6,7,8,9,10])\n",
    "print(arr**2)\n",
    "print(arr+10)\n",
    "print(arr+arr2)"
   ]
  },
