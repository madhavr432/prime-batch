import numpy as np


arr = np.array([1,2,3,4,5])
print(arr, arr.dtype)


arr = np.array([1,2,3.14,5])
print(arr, arr.dtype)


arr = np.array([1,2,3.14,5,"hello"])
print(arr, arr.dtype)


#complex no.
arr = np.array([3+5j])
print(arr,arr.dtype)


arr1 = np.array([3+5j])
arr2 = np.array([2+3j])
print(arr1 + arr2)


arr = np.array(["prime", {1, 2, 3}, 3.14])
print(arr, arr.dtype)
